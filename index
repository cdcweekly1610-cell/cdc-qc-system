<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>【CDC】工程品管自檢查詢系統</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Vue 3 CDN -->
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <!-- FontAwesome 陸續圖標 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Noto Sans TC', sans-serif;
            background-color: #f8fafc;
        }
        .scrollbar-thin::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        .scrollbar-thin::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        .scrollbar-thin::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 3px;
        }
    </style>
</head>
<body class="text-slate-800 antialiased">
    <div id="app" class="min-h-screen flex flex-col justify-between">
        
        <!-- 頂部導覽列 -->
        <header class="bg-slate-900 text-white shadow-lg border-b-4 border-amber-500 sticky top-0 z-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="flex items-center justify-between h-16">
                    <div class="flex items-center space-x-3">
                        <div class="bg-amber-500 text-slate-900 p-2 rounded-lg font-black text-xl flex items-center justify-center shadow-inner">
                            <i class="fa-solid fa-screwdriver-wrench"></i>
                        </div>
                        <div>
                            <span class="font-extrabold text-lg sm:text-xl tracking-wider block">【CDC】工程品管自檢查詢系統</span>
                            <span class="text-xs text-slate-400 -mt-1 block">專業品管專用數據管理門戶</span>
                        </div>
                    </div>
                    <div class="flex items-center space-x-2">
                        <a href="https://docs.google.com/spreadsheets/d/1KIbDQtS6MzNU2RwqJg7mhw3obCm1NPEeyFa6l1YxfV0/edit?gid=424333769#gid=424333769" 
                           target="_blank" 
                           class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs sm:text-sm font-semibold py-2 px-3 sm:px-4 rounded-lg flex items-center space-x-1 transition shadow-md">
                            <i class="fa-solid fa-file-excel"></i>
                            <span class="hidden sm:inline">開啟雲端試算表</span>
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <!-- 主體內容區 -->
        <main class="flex-grow max-w-7xl w-full mx-auto px-4 sm:px-6 lg:px-8 py-6">
            
            <!-- 品管員引言與提醒 -->
            <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border-l-4 border-blue-500 p-4 rounded-r-xl mb-6 shadow-sm flex items-start space-x-3">
                <div class="bg-blue-500 text-white p-2 rounded-full hidden sm:block">
                    <i class="fa-solid fa-user-tie"></i>
                </div>
                <div>
                    <h3 class="text-blue-950 font-bold text-sm sm:text-base">品管日誌 & 數據提醒</h3>
                    <p class="text-blue-900 text-xs sm:text-sm mt-1 leading-relaxed">
                        您好！本系統資料來源為 <span class="font-semibold underline">【CDC】自檢次數統計表</span>。
                        根據最新交叉比對，目前共有 <strong>7 項工程主工項</strong>，其中「擋土排樁」自檢次數最高（共 226 次，合格率 98%）。
                        您可以在此快速查詢各工項最新流水號、一鍵複製下一號編碼，並於頁面下方瀏覽最新自檢紀錄明細。
                    </p>
                </div>
            </div>

            <!-- KPI 資訊卡 -->
            <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-100 flex items-center justify-between">
                    <div>
                        <span class="text-xs text-slate-400 block font-semibold">主工項數量</span>
                        <span class="text-2xl font-black text-slate-800">{{ workItems.length }} <span class="text-xs font-normal text-slate-500">項</span></span>
                    </div>
                    <div class="text-blue-500 bg-blue-50 p-3 rounded-lg text-lg"><i class="fa-solid fa-layer-group"></i></div>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-100 flex items-center justify-between">
                    <div>
                        <span class="text-xs text-slate-400 block font-semibold">自檢總次數</span>
                        <span class="text-2xl font-black text-slate-800">{{ totalCheckCount }} <span class="text-xs font-normal text-slate-500">次</span></span>
                    </div>
                    <div class="text-indigo-500 bg-indigo-50 p-3 rounded-lg text-lg"><i class="fa-solid fa-clipboard-check"></i></div>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-100 flex items-center justify-between">
                    <div>
                        <span class="text-xs text-slate-400 block font-semibold">整體合格率</span>
                        <span class="text-2xl font-black text-emerald-600">{{ overallPassRate }}%</span>
                    </div>
                    <div class="text-emerald-500 bg-emerald-50 p-3 rounded-lg text-lg"><i class="fa-solid fa-circle-check"></i></div>
                </div>
                <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-100 flex items-center justify-between">
                    <div>
                        <span class="text-xs text-slate-400 block font-semibold">不合格待改善</span>
                        <span class="text-2xl font-black text-rose-500">{{ totalFailCount }} <span class="text-xs font-normal text-slate-500">件</span></span>
                    </div>
                    <div class="text-rose-500 bg-rose-50 p-3 rounded-lg text-lg"><i class="fa-solid fa-triangle-exclamation"></i></div>
                </div>
            </div>

            <!-- 自訂通知提示 (Toast) -->
            <transition name="fade">
                <div v-if="toastMessage" class="fixed top-20 right-4 sm:right-8 bg-slate-900 text-white px-4 py-3 rounded-xl shadow-2xl z-50 flex items-center space-x-2 border-l-4 border-amber-500">
                    <span class="text-amber-400"><i class="fa-solid fa-circle-info"></i></span>
                    <span class="text-sm font-medium">{{ toastMessage }}</span>
                </div>
            </transition>

            <!-- 兩欄式區塊：左側工項搜尋與最新編號，右側快速號碼產生器 -->
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                
                <!-- 左側：工項與編號清單 (佔2欄) -->
                <div class="lg:col-span-2 flex flex-col space-y-4">
                    <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm border border-slate-100">
                        
                        <div class="sm:flex sm:items-center sm:justify-between pb-4 border-b border-slate-100 mb-4">
                            <div>
                                <h2 class="text-lg font-black text-slate-900 flex items-center space-x-2">
                                    <span class="inline-block w-2.5 h-5 bg-amber-500 rounded-sm"></span>
                                    <span>工項與最新流水號統計表</span>
                                </h2>
                                <p class="text-slate-400 text-xs mt-0.5">提供工項最新流水號 (LAST)、合格率及前綴編碼快速檢視</p>
                            </div>
                            
                            <!-- 搜尋欄 -->
                            <div class="mt-3 sm:mt-0 relative rounded-lg shadow-sm max-w-xs w-full">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none text-slate-400">
                                    <i class="fa-solid fa-magnifying-glass text-xs"></i>
                                </div>
                                <input type="text" 
                                       v-model="workQuery" 
                                       placeholder="搜尋工項名稱、代碼 (如 EA54)" 
                                       class="block w-full pl-9 pr-3 py-1.5 text-sm bg-slate-50 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 focus:bg-white transition">
                            </div>
                        </div>

                        <!-- 表格區 (RWD 可滑動) -->
                        <div class="overflow-x-auto scrollbar-thin">
                            <table class="min-w-full divide-y divide-slate-100 text-left text-sm">
                                <thead class="bg-slate-50 text-slate-500 font-semibold text-xs uppercase tracking-wider">
                                    <tr>
                                        <th class="px-4 py-3 rounded-l-lg">工項名稱</th>
                                        <th class="px-4 py-3">前綴編碼</th>
                                        <th class="px-4 py-3 text-center">自檢次數</th>
                                        <th class="px-4 py-3 text-center">合格 / 不合格</th>
                                        <th class="px-4 py-3 text-center">合格率</th>
                                        <th class="px-4 py-3 text-right rounded-r-lg">最後流水號 (LAST)</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100 text-slate-600 font-medium">
                                    <tr v-for="item in filteredWorkItems" 
                                        :key="item.code" 
                                        @click="selectWorkItem(item)"
                                        :class="['hover:bg-amber-50/40 cursor-pointer transition', selectedItem && selectedItem.code === item.code ? 'bg-amber-50/60' : '']">
                                        <td class="px-4 py-3.5">
                                            <div class="font-bold text-slate-800">{{ item.name }}</div>
                                        </td>
                                        <td class="px-4 py-3.5">
                                            <span class="bg-slate-100 text-slate-700 px-2 py-0.5 rounded text-xs font-mono font-bold border border-slate-200">{{ item.code }}</span>
                                        </td>
                                        <td class="px-4 py-3.5 text-center font-bold text-slate-700">
                                            {{ item.total }} <span class="text-xs font-normal text-slate-400">次</span>
                                        </td>
                                        <td class="px-4 py-3.5 text-center">
                                            <span class="text-emerald-600 font-semibold">{{ item.passed }}</span>
                                            <span class="text-slate-300 mx-1">/</span>
                                            <span class="font-semibold" :class="item.failed > 0 ? 'text-rose-500' : 'text-slate-400'">{{ item.failed }}</span>
                                        </td>
                                        <td class="px-4 py-3.5 text-center">
                                            <div class="inline-flex items-center space-x-1">
                                                <div class="w-12 bg-slate-100 rounded-full h-1.5 overflow-hidden hidden sm:block">
                                                    <div class="bg-emerald-500 h-full" :style="{ width: item.rate }"></div>
                                                </div>
                                                <span :class="['text-xs font-bold', item.rate === '100%' ? 'text-emerald-600' : 'text-amber-600']">{{ item.rate }}</span>
                                            </div>
                                        </td>
                                        <td class="px-4 py-3.5 text-right font-mono font-bold text-blue-600">
                                            <div class="flex items-center justify-end space-x-1">
                                                <span class="bg-blue-50 text-blue-700 px-2.5 py-1 rounded-md text-sm border border-blue-100 shadow-sm">{{ item.lastNo }}</span>
                                                <button @click.stop="quickCopy(item.lastNo, '已複製最後編號: ' + item.lastNo)" 
                                                        class="text-slate-400 hover:text-slate-600 p-1 rounded hover:bg-slate-100 transition" 
                                                        title="一鍵複製最後編號">
                                                    <i class="fa-regular fa-copy"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <tr v-if="filteredWorkItems.length === 0">
                                        <td colspan="6" class="text-center py-8 text-slate-400">
                                            <i class="fa-regular fa-folder-open text-2xl block mb-2"></i>
                                            找不到符合關鍵字的工項資料
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>

                <!-- 右側：編號速算與操作面板 (佔1欄) -->
                <div class="lg:col-span-1">
                    <div class="bg-slate-900 text-white p-5 rounded-2xl shadow-lg border border-slate-800 flex flex-col justify-between h-full min-h-[380px]">
                        <div>
                            <div class="flex items-center justify-between pb-3 border-b border-slate-800 mb-4">
                                <h3 class="font-black text-base text-amber-400 flex items-center space-x-2">
                                    <i class="fa-solid fa-calculator"></i>
                                    <span>品管編號小幫手</span>
                                </h3>
                                <span class="bg-slate-800 text-slate-400 text-[10px] px-2 py-0.5 rounded font-mono">Auto-Calc</span>
                            </div>

                            <div v-if="selectedItem">
                                <div class="space-y-4">
                                    <!-- 已選擇工項 -->
                                    <div>
                                        <span class="text-xs text-slate-400 block font-medium">當前選取工項</span>
                                        <span class="text-lg font-black text-white">{{ selectedItem.name }}</span>
                                        <span class="text-xs text-slate-400 ml-2 font-mono">({{ selectedItem.code }})</span>
                                    </div>

                                    <!-- 最新編號 & 下一編號計算器 -->
                                    <div class="grid grid-cols-2 gap-3 bg-slate-950 p-3 rounded-xl border border-slate-800">
                                        <div>
                                            <span class="text-[11px] text-slate-500 block font-semibold">最後編號 (LAST)</span>
                                            <span class="text-base font-mono font-bold text-blue-400 block mt-0.5">{{ selectedItem.lastNo }}</span>
                                        </div>
                                        <div>
                                            <span class="text-[11px] text-amber-500 block font-semibold">下一號建議</span>
                                            <span class="text-base font-mono font-bold text-amber-400 block mt-0.5">{{ nextSerialNo }}</span>
                                        </div>
                                    </div>

                                    <!-- 新流水號拷貝按鈕 -->
                                    <button @click="quickCopy(nextSerialNo, '已複製新流水號: ' + nextSerialNo)"
                                            class="w-full bg-amber-500 hover:bg-amber-600 active:bg-amber-700 text-slate-950 font-black py-2.5 px-4 rounded-xl flex items-center justify-center space-x-2 shadow-lg transition duration-150 text-sm">
                                        <i class="fa-regular fa-copy"></i>
                                        <span>複製下一號：{{ nextSerialNo }}</span>
                                    </button>

                                    <!-- 修改最後編號設定 -->
                                    <div class="pt-3 border-t border-slate-800">
                                        <label class="text-xs text-slate-400 block mb-1">手動變更最後流水號</label>
                                        <div class="flex space-x-2">
                                            <input type="text" 
                                                   v-model="editLastNo" 
                                                   class="bg-slate-950 border border-slate-800 rounded-lg px-2.5 py-1.5 text-sm font-mono focus:outline-none focus:ring-1 focus:ring-amber-500 flex-grow text-white">
                                            <button @click="updateLastNo" 
                                                    class="bg-slate-800 hover:bg-slate-700 text-xs px-3 rounded-lg font-semibold border border-slate-700 transition">
                                                更新
                                            </button>
                                        </div>
                                        <span class="text-[10px] text-slate-500 mt-1 block">若在試算表新增了查驗，可在這直接更新同步。</span>
                                    </div>
                                </div>
                            </div>
                            <div v-else class="text-center py-10 text-slate-500">
                                <i class="fa-solid fa-arrow-pointer text-3xl mb-3 block text-slate-600"></i>
                                <p class="text-xs">請點選左側表格中的工項</p>
                                <p class="text-[11px] mt-1 text-slate-600">即可自動產生下一個流水號</p>
                            </div>
                        </div>

                        <!-- 快速指南 -->
                        <div class="mt-6 pt-3 border-t border-slate-800 text-[11px] text-slate-400 leading-relaxed">
                            <i class="fa-solid fa-lightbulb text-amber-400 mr-1"></i>
                            <strong>快速指南：</strong> 點選任一工項，系統會自動解構編號並遞增最後一碼數值（例如：<span class="font-mono text-slate-300">EA54-109</span> $\rightarrow$ <span class="font-mono text-amber-300">EA54-110</span>），助您快速填寫最新紙本或雲端紀錄。
                        </div>
                    </div>
                </div>

            </div>

            <!-- 下方區塊：最新自檢項目 -->
            <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm border border-slate-100 mb-8">
                
                <div class="sm:flex sm:items-center sm:justify-between pb-4 border-b border-slate-100 mb-4">
                    <div>
                        <h2 class="text-lg font-black text-slate-900 flex items-center space-x-2">
                            <span class="inline-block w-2.5 h-5 bg-blue-500 rounded-sm"></span>
                            <span>最新自檢回覆項目（自檢紀錄）</span>
                        </h2>
                        <p class="text-slate-400 text-xs mt-0.5">顯示從表單最新回覆的工地自主查驗項目與進度</p>
                    </div>

                    <!-- 篩選器面板 -->
                    <div class="mt-3 sm:mt-0 flex flex-wrap gap-2">
                        <!-- 工項篩選 -->
                        <select v-model="filterWorkItem" 
                                class="bg-slate-50 border border-slate-200 rounded-lg px-2.5 py-1.5 text-xs font-semibold text-slate-600 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            <option value="">全部工項</option>
                            <option v-for="item in workItems" :key="item.name" :value="item.name">{{ item.name }}</option>
                        </select>
                        <!-- 監造查驗狀態篩選 -->
                        <select v-model="filterSupervised" 
                                class="bg-slate-50 border border-slate-200 rounded-lg px-2.5 py-1.5 text-xs font-semibold text-slate-600 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            <option value="">全部監造狀態</option>
                            <option value="是">已監造查驗</option>
                            <option value="否">未監造查驗</option>
                        </select>
                        <button @click="showAddRecordModal = true" 
                                class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-bold px-3 py-1.5 rounded-lg flex items-center space-x-1 transition shadow">
                            <i class="fa-solid fa-plus"></i>
                            <span>新增自檢</span>
                        </button>
                    </div>
                </div>

                <!-- 自檢紀錄條目 -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div v-for="rec in filteredRecords" 
                         :key="rec.timestamp" 
                         class="bg-slate-50 p-4 rounded-xl border border-slate-100 hover:border-blue-200 hover:bg-blue-50/10 transition flex flex-col justify-between">
                        
                        <div>
                            <!-- 上層：工項與狀態標籤 -->
                            <div class="flex items-center justify-between mb-3">
                                <span class="bg-blue-100 text-blue-800 text-xs font-extrabold px-2.5 py-1 rounded-md">
                                    {{ rec.workItem }}
                                </span>
                                <div class="flex items-center space-x-2">
                                    <span v-if="rec.isSupervised === '是'" class="bg-emerald-100 text-emerald-800 text-[11px] font-bold px-2 py-0.5 rounded-full flex items-center space-x-1">
                                        <i class="fa-solid fa-circle-check"></i>
                                        <span>監造已查驗</span>
                                    </span>
                                    <span v-else class="bg-amber-100 text-amber-800 text-[11px] font-bold px-2 py-0.5 rounded-full flex items-center space-x-1">
                                        <i class="fa-solid fa-clock"></i>
                                        <span>自主檢查中</span>
                                    </span>
                                    <button @click="deleteRecord(rec.timestamp)" 
                                            class="text-slate-300 hover:text-rose-500 p-1 transition"
                                            title="刪除此紀錄">
                                        <i class="fa-solid fa-trash-can text-xs"></i>
                                    </button>
                                </div>
                            </div>

                            <!-- 中層：查驗項目名稱與位置 -->
                            <h4 class="font-extrabold text-base text-slate-800">{{ rec.checkItem }}</h4>
                            <div class="text-xs text-slate-500 mt-1.5 space-y-1">
                                <div class="flex items-center space-x-1">
                                    <i class="fa-solid fa-location-dot text-slate-400 w-4"></i>
                                    <span>查驗位置：<strong class="text-slate-700">{{ rec.location }}</strong></span>
                                </div>
                                <div class="flex items-center space-x-1">
                                    <i class="fa-regular fa-calendar text-slate-400 w-4"></i>
                                    <span>自檢日期：{{ rec.date }}</span>
                                </div>
                                <div v-if="rec.isSupervised === '是'" class="flex items-center space-x-1 text-emerald-700">
                                    <i class="fa-solid fa-user-check w-4"></i>
                                    <span>查驗監造：<strong>{{ rec.supervisor }}</strong> ({{ rec.supervisionDate || rec.date }})</span>
                                </div>
                            </div>
                        </div>

                        <!-- 下層：照片連結與時間戳記 -->
                        <div class="mt-4 pt-3 border-t border-slate-200/60 flex items-center justify-between text-xs">
                            <span class="text-slate-400 font-mono">填報時間: {{ rec.timestamp }}</span>
                            
                            <!-- 照片雲端按鈕 -->
                            <div class="flex items-center space-x-1.5">
                                <span class="text-slate-400 mr-1"><i class="fa-solid fa-image text-xs"></i> {{ rec.photos ? rec.photos.length : 0 }} 張照片:</span>
                                <a v-for="(photoUrl, pIndex) in rec.photos" 
                                   :key="pIndex"
                                   :href="photoUrl" 
                                   target="_blank" 
                                   class="bg-blue-50 text-blue-600 hover:bg-blue-100 hover:text-blue-800 font-bold w-6 h-6 rounded flex items-center justify-center transition border border-blue-100"
                                   :title="'查看照片 ' + (pIndex + 1)">
                                    {{ pIndex + 1 }}
                                </a>
                                <span v-if="!rec.photos || rec.photos.length === 0" class="text-slate-400 italic">無附圖</span>
                            </div>
                        </div>

                    </div>

                    <div v-if="filteredRecords.length === 0" class="md:col-span-2 text-center py-10 bg-slate-50 rounded-xl border border-dashed border-slate-200 text-slate-400">
                        <i class="fa-solid fa-list-check text-3xl mb-2"></i>
                        <p class="text-xs">目前無符合篩選條件的自檢紀錄</p>
                    </div>
                </div>

            </div>

            <!-- 手動更新與大量 CSV 導入區 -->
            <div class="bg-white p-4 sm:p-6 rounded-2xl shadow-sm border border-slate-100">
                <div class="pb-3 border-b border-slate-100 mb-4 flex items-center justify-between">
                    <h2 class="text-sm sm:text-base font-black text-slate-900 flex items-center space-x-2">
                        <i class="fa-solid fa-arrows-rotate text-blue-500"></i>
                        <span>試算表數據同步管理面板 (CSV 直接導入)</span>
                    </h2>
                    <button @click="resetToDefault" class="text-xs text-rose-500 hover:text-rose-700 font-bold transition flex items-center space-x-1">
                        <i class="fa-solid fa-trash-arrow-up"></i>
                        <span>還原初始預設值</span>
                    </button>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-xs sm:text-sm">
                    <!-- 1. 說明 -->
                    <div class="space-y-2 text-slate-500 leading-relaxed">
                        <p class="font-bold text-slate-700">如何隨時從雲端 Excel / Google 試算表更新本機網頁數據？</p>
                        <ol class="list-decimal list-inside space-y-1">
                            <li>開啟您的雲端 Google 試算表 <a href="https://docs.google.com/spreadsheets/d/1KIbDQtS6MzNU2RwqJg7mhw3obCm1NPEeyFa6l1YxfV0/edit?gid=424333769#gid=424333769" target="_blank" class="text-blue-500 underline font-bold">開啟連結</a></li>
                            <li>選取並複製「總次數」表格區域（欄位需包含 <strong>工項、總次數、合格、不合格、合格率、編號、LAST</strong>）</li>
                            <li>將其轉換為 CSV 格式（或直接整列複製貼上到右側輸入框）</li>
                            <li>點擊「解析並導入工項」，網頁將即時重新計算，不需重新寫程式！</li>
                        </ol>
                        <p class="text-[11px] text-amber-600 bg-amber-50 p-2.5 rounded-lg border border-amber-200 mt-2">
                            <i class="fa-solid fa-triangle-exclamation mr-1"></i>
                            註：此系統會將資料安全地存儲在您的瀏覽器暫存 (Local Storage) 中，重開網頁數據也不會消失！
                        </p>
                    </div>

                    <!-- 2. 輸入與導入 -->
                    <div class="space-y-3">
                        <label class="block font-bold text-slate-700">貼上「工項與編號」資料 (CSV 格式或 Tab 分隔)</label>
                        <textarea v-model="csvText" 
                                  placeholder="工項,總次數,合格,不合格,合格率,編號,LAST&#10;安全監測,64,64,0,100%,EA04,EA04-017&#10;拆除,96,96,0,100%,EA26,EA26-016" 
                                  class="w-full h-24 bg-slate-50 border border-slate-200 rounded-lg p-2 font-mono text-xs focus:outline-none focus:ring-1 focus:ring-blue-500"
                                  rows="3"></textarea>
                        <button @click="importCSV" 
                                class="w-full bg-slate-800 hover:bg-slate-900 text-white font-bold py-2 rounded-lg text-xs transition shadow">
                            解析並匯入工項數據
                        </button>
                    </div>
                </div>
            </div>

        </main>

        <!-- 新增自檢紀錄模組 (Modal) -->
        <div v-if="showAddRecordModal" class="fixed inset-0 bg-slate-900/50 flex items-center justify-center p-4 z-50">
            <div class="bg-white rounded-2xl max-w-lg w-full p-6 shadow-2xl border border-slate-100 overflow-y-auto max-h-[90vh]">
                <div class="flex items-center justify-between pb-3 border-b border-slate-100 mb-4">
                    <h3 class="font-extrabold text-base text-slate-900 flex items-center space-x-1.5">
                        <i class="fa-solid fa-clipboard-list text-blue-500"></i>
                        <span>新增自主檢查項目</span>
                    </h3>
                    <button @click="showAddRecordModal = false" class="text-slate-400 hover:text-slate-600 transition">
                        <i class="fa-solid fa-xmark text-lg"></i>
                    </button>
                </div>
                
                <form @submit.prevent="submitRecord" class="space-y-4 text-xs sm:text-sm">
                    <!-- 工項名稱選擇 -->
                    <div>
                        <label class="block text-slate-600 font-bold mb-1">工項名稱 *</label>
                        <select v-model="newRecord.workItem" required 
                                class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white">
                            <option value="">請選擇對應工項</option>
                            <option v-for="item in workItems" :key="item.name" :value="item.name">{{ item.name }}</option>
                        </select>
                    </div>

                    <!-- 查驗項目 -->
                    <div>
                        <label class="block text-slate-600 font-bold mb-1">自檢查驗項目 *</label>
                        <input type="text" v-model="newRecord.checkItem" required placeholder="如：預壘樁鋼筋籠綁紮"
                               class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white">
                    </div>

                    <!-- 位置說明 -->
                    <div>
                        <label class="block text-slate-600 font-bold mb-1">查驗位置說明 *</label>
                        <input type="text" v-model="newRecord.location" required placeholder="如：西南角、LINE 1/A"
                               class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2.5 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white">
                    </div>

                    <div class="grid grid-cols-2 gap-4">
                        <!-- 自檢日期 -->
                        <div>
                            <label class="block text-slate-600 font-bold mb-1">自檢日期 *</label>
                            <input type="date" v-model="newRecord.date" required
                                   class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white">
                        </div>
                        <!-- 時間戳記 (自動產生) -->
                        <div>
                            <label class="block text-slate-400 font-bold mb-1">填報時間 (自動)</label>
                            <input type="text" :value="autoTimestamp" disabled
                                   class="w-full bg-slate-100 border border-slate-200 text-slate-400 rounded-lg p-2 select-none cursor-not-allowed">
                        </div>
                    </div>

                    <!-- 監造是否查驗 -->
                    <div>
                        <label class="block text-slate-600 font-bold mb-1">是否已經與監造查驗？</label>
                        <div class="flex space-x-4 mt-1">
                            <label class="inline-flex items-center cursor-pointer">
                                <input type="radio" v-model="newRecord.isSupervised" value="是" class="text-blue-600 focus:ring-blue-500 h-4 w-4">
                                <span class="ml-2 font-semibold">是</span>
                            </label>
                            <label class="inline-flex items-center cursor-pointer">
                                <input type="radio" v-model="newRecord.isSupervised" value="否" class="text-blue-600 focus:ring-blue-500 h-4 w-4">
                                <span class="ml-2 font-semibold">否</span>
                            </label>
                        </div>
                    </div>

                    <!-- 若監造已查驗，填寫細節 -->
                    <div v-if="newRecord.isSupervised === '是'" class="p-3 bg-slate-50 rounded-xl border border-slate-100 space-y-3">
                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="block text-slate-600 font-semibold mb-1 text-xs">監造查驗人員 *</label>
                                <input type="text" v-model="newRecord.supervisor" required placeholder="祝本忠"
                                       class="w-full bg-white border border-slate-200 rounded-lg p-2 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            </div>
                            <div>
                                <label class="block text-slate-600 font-semibold mb-1 text-xs">監造查驗日期</label>
                                <input type="date" v-model="newRecord.supervisionDate"
                                       class="w-full bg-white border border-slate-200 rounded-lg p-2 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            </div>
                        </div>
                    </div>

                    <!-- 照片連結 -->
                    <div>
                        <label class="block text-slate-600 font-bold mb-1">請輸入雲端照片連結 (多個請用半形逗號分隔)</label>
                        <textarea v-model="newRecord.photoString" placeholder="https://drive.google.com/open?id=123..." 
                                  class="w-full bg-slate-50 border border-slate-200 rounded-lg p-2 h-16 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:bg-white text-xs"></textarea>
                    </div>

                    <div class="flex justify-end space-x-3 pt-3 border-t border-slate-100">
                        <button type="button" @click="showAddRecordModal = false" 
                                class="px-4 py-2 border border-slate-200 rounded-lg font-bold text-slate-500 hover:bg-slate-50 transition">
                            取消
                        </button>
                        <button type="submit" 
                                class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-lg shadow transition">
                            完成並提交
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- 頁尾 -->
        <footer class="bg-slate-900 text-slate-400 py-6 border-t border-slate-800">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-xs space-y-2">
                <p>【CDC】工程品管自檢查詢系統 &copy; 2026. 專供工區品管自檢及編號查詢使用。</p>
                <p class="text-slate-600">
                    資料來源與內文比對：Google Drive 檔案 <a class="underline hover:text-slate-400" href="https://docs.google.com/spreadsheets/d/1KIbDQtS6MzNU2RwqJg7mhw3obCm1NPEeyFa6l1YxfV0/edit?gid=424333769#gid=424333769" target="_blank">【CDC】自檢次數統計表 (總次數)</a> 
                    &middot; 自檢紀錄 (表單回覆 1)。
                </p>
            </div>
        </footer>

    </div>

    <script>
        const { createApp, ref, computed, onMounted, watch } = Vue;

        // 預設之品管工項數據 (源自 【CDC】自檢次數統計表)
        const DEFAULT_WORK_ITEMS = [
            { name: "安全監測", total: 64, passed: 64, failed: 0, rate: "100%", code: "EA04", lastNo: "EA04-017" },
            { name: "拆除", total: 96, passed: 96, failed: 0, rate: "100%", code: "EA26", lastNo: "EA26-016" },
            { name: "衛福部車道拓寬", total: 10, passed: 10, failed: 0, rate: "100%", code: "EA52", lastNo: "EA52-008" },
            { name: "微型樁", total: 252, passed: 252, failed: 0, rate: "100%", code: "EA53", lastNo: "EA53-037" },
            { name: "假設", total: 89, passed: 88, failed: 1, rate: "99%", code: "EA51", lastNo: "EA51-035" },
            { name: "擋土排樁", total: 226, passed: 222, failed: 4, rate: "98%", code: "EA54", lastNo: "EA54-109" },
            { name: "放樣", total: 15, passed: 15, failed: 0, rate: "100%", code: "EA55", lastNo: "EA55-001" }
        ];

        // 預設之自檢紀錄 (源自 試算表 - 表單回覆 1)
        const DEFAULT_RECORDS = [
            {
                timestamp: "2026/5/16 下午 5:53:55",
                date: "2025/05/15",
                workItem: "擋土排樁",
                checkItem: "預壘樁劣質打除",
                location: "LINE 1/A",
                photos: [
                    "https://drive.google.com/open?id=1raHmvS3jYm521fqTm-29VS7UuaBnV5kY",
                    "https://drive.google.com/open?id=1Jddx0lbA8klomTl5YpgyGb3kcAqfeXVL"
                ],
                isSupervised: "否",
                supervisionDate: "",
                supervisor: ""
            },
            {
                timestamp: "2026/5/16 下午 5:39:48",
                date: "2025/05/15",
                workItem: "擋土排樁",
                checkItem: "預壘樁鋼筋籠綁紮",
                location: "預壘樁西南角",
                photos: [
                    "https://drive.google.com/open?id=1YUUzucS6ZRHsZ1_RlQpOn661gfQWuxYX",
                    "https://drive.google.com/open?id=1r8oupD5ujnbHHI3hNZxIJ80ldAn024gM"
                ],
                isSupervised: "是",
                supervisionDate: "2025/05/15",
                supervisor: "祝本忠"
            }
        ];

        createApp({
            setup() {
                // 狀態定義
                const workItems = ref([]);
                const records = ref([]);
                
                const workQuery = ref('');
                const selectedItem = ref(null);
                const editLastNo = ref('');
                
                const filterWorkItem = ref('');
                const filterSupervised = ref('');
                
                const showAddRecordModal = ref(false);
                const toastMessage = ref('');
                
                // 批量導入用 CSV text
                const csvText = ref('');

                // 新建表單欄位
                const newRecord = ref({
                    workItem: '',
                    checkItem: '',
                    location: '',
                    date: new Date().toISOString().substring(0, 10),
                    isSupervised: '否',
                    supervisor: '',
                    supervisionDate: '',
                    photoString: ''
                });

                // 初始化加載
                onMounted(() => {
                    const localItems = localStorage.getItem('cdc_work_items');
                    const localRecords = localStorage.getItem('cdc_records');
                    
                    if (localItems) {
                        workItems.value = JSON.parse(localItems);
                    } else {
                        workItems.value = JSON.parse(JSON.stringify(DEFAULT_WORK_ITEMS));
                    }

                    if (localRecords) {
                        records.value = JSON.parse(localRecords);
                    } else {
                        records.value = JSON.parse(JSON.stringify(DEFAULT_RECORDS));
                    }

                    // 預設選中第一個工項
                    if (workItems.value.length > 0) {
                        selectWorkItem(workItems.value[5]); // 預設選中 擋土排樁
                    }
                });

                // 儲存至本地暫存
                const saveToLocal = () => {
                    localStorage.setItem('cdc_work_items', JSON.stringify(workItems.value));
                    localStorage.setItem('cdc_records', JSON.stringify(records.value));
                };

                // 品管通知提示
                const triggerToast = (msg) => {
                    toastMessage.value = msg;
                    setTimeout(() => {
                        toastMessage.value = '';
                    }, 3500);
                };

                // 工項選擇
                const selectWorkItem = (item) => {
                    selectedItem.value = item;
                    editLastNo.value = item.lastNo;
                };

                // 流水號自動加 1 解析計算器
                const nextSerialNo = computed(() => {
                    if (!selectedItem.value) return '';
                    const last = selectedItem.value.lastNo;
                    // 正則拆分字尾數字：例如 EA54-109 拆成 EA54- 和 109
                    const match = last.match(/^(.*?)(\d+)$/);
                    if (match) {
                        const prefix = match[1];
                        const numberStr = match[2];
                        const nextNumber = parseInt(numberStr, 10) + 1;
                        // 保持原本數字的長度填充：如 017 加 1 變成 018，109 加 1 變 110
                        const paddedNumber = String(nextNumber).padStart(numberStr.length, '0');
                        return `${prefix}${paddedNumber}`;
                    }
                    return `${selectedItem.value.code}-001`;
                });

                // 手動更新 LAST 編號
                const updateLastNo = () => {
                    if (selectedItem.value && editLastNo.value.trim()) {
                        selectedItem.value.lastNo = editLastNo.value.trim();
                        triggerToast(`已手動將 ${selectedItem.value.name} 最後編號更新為：${selectedItem.value.lastNo}`);
                        saveToLocal();
                    }
                };

                // 篩選工項表格
                const filteredWorkItems = computed(() => {
                    const query = workQuery.value.trim().toLowerCase();
                    if (!query) return workItems.value;
                    return workItems.value.filter(item => 
                        item.name.toLowerCase().includes(query) || 
                        item.code.toLowerCase().includes(query) ||
                        item.lastNo.toLowerCase().includes(query)
                    );
                });

                // 篩選最新自檢紀錄
                const filteredRecords = computed(() => {
                    let res = records.value;
                    if (filterWorkItem.value) {
                        res = res.filter(r => r.workItem === filterWorkItem.value);
                    }
                    if (filterSupervised.value) {
                        res = res.filter(r => r.isSupervised === filterSupervised.value);
                    }
                    // 按時間戳記由新到舊排序
                    return res.sort((a, b) => new Date(b.timestamp.replace('下午', 'PM').replace('上午', 'AM')) - new Date(a.timestamp.replace('下午', 'PM').replace('上午', 'AM')));
                });

                // 計算整體 KPI
                const totalCheckCount = computed(() => {
                    return workItems.value.reduce((acc, curr) => acc + curr.total, 0);
                });

                const totalPassCount = computed(() => {
                    return workItems.value.reduce((acc, curr) => acc + curr.passed, 0);
                });

                const totalFailCount = computed(() => {
                    return workItems.value.reduce((acc, curr) => acc + curr.failed, 0);
                });

                const overallPassRate = computed(() => {
                    if (totalCheckCount.value === 0) return 0;
                    return Math.round((totalPassCount.value / totalCheckCount.value) * 100);
                });

                // 自動取得當前時間戳記
                const autoTimestamp = computed(() => {
                    const now = new Date();
                    const hours = now.getHours();
                    const ampm = hours >= 12 ? '下午' : '上午';
                    const displayHours = hours % 12 || 12;
                    return `${now.getFullYear()}/${now.getMonth() + 1}/${now.getDate()} ${ampm} ${displayHours}:${String(now.getMinutes()).padStart(2, '0')}:${String(now.getSeconds()).padStart(2, '0')}`;
                });

                // 提交新的自檢紀錄表單
                const submitRecord = () => {
                    const photoList = newRecord.value.photoString.trim()
                        ? newRecord.value.photoString.split(',').map(url => url.trim()).filter(url => url !== '')
                        : [];
                    
                    const newEntry = {
                        timestamp: autoTimestamp.value,
                        date: newRecord.value.date.replace(/-/g, '/'),
                        workItem: newRecord.value.workItem,
                        checkItem: newRecord.value.checkItem,
                        location: newRecord.value.location,
                        photos: photoList,
                        isSupervised: newRecord.value.isSupervised,
                        supervisionDate: newRecord.value.isSupervised === '是' ? newRecord.value.supervisionDate.replace(/-/g, '/') : '',
                        supervisor: newRecord.value.isSupervised === '是' ? newRecord.value.supervisor : ''
                    };

                    records.value.unshift(newEntry);

                    // 同步增量更新對應工項的檢查次數 (預設新增自檢合格)
                    const targetWork = workItems.value.find(w => w.name === newRecord.value.workItem);
                    if (targetWork) {
                        targetWork.total += 1;
                        targetWork.passed += 1;
                        targetWork.rate = Math.round((targetWork.passed / targetWork.total) * 100) + '%';
                    }

                    saveToLocal();
                    triggerToast(`自檢項目填報成功！已自動累加「${newRecord.value.workItem}」自檢次數。`);
                    showAddRecordModal.value = false;

                    // 重置表單
                    newRecord.value = {
                        workItem: '',
                        checkItem: '',
                        location: '',
                        date: new Date().toISOString().substring(0, 10),
                        isSupervised: '否',
                        supervisor: '',
                        supervisionDate: '',
                        photoString: ''
                    };
                };

                // 刪除自檢紀錄
                const deleteRecord = (ts) => {
                    const recordToDelete = records.value.find(r => r.timestamp === ts);
                    if (!recordToDelete) return;
                    
                    if (confirm(`確定要刪除此筆填報時間為 ${ts} 的自檢紀錄嗎？`)) {
                        records.value = records.value.filter(r => r.timestamp !== ts);
                        
                        // 扣除對應工項的次數
                        const targetWork = workItems.value.find(w => w.name === recordToDelete.workItem);
                        if (targetWork && targetWork.total > 0) {
                            targetWork.total -= 1;
                            if (targetWork.passed > 0) targetWork.passed -= 1;
                            targetWork.rate = targetWork.total > 0 ? (Math.round((targetWork.passed / targetWork.total) * 100) + '%') : '100%';
                        }

                        saveToLocal();
                        triggerToast(`自檢紀錄已刪除，統計數據已重新校正。`);
                    }
                };

                // 一鍵複製編號 (iFrame 友善版)
                const quickCopy = (text, message) => {
                    const textarea = document.createElement('textarea');
                    textarea.value = text;
                    textarea.style.position = 'fixed';
                    document.body.appendChild(textarea);
                    textarea.focus();
                    textarea.select();
                    try {
                        const successful = document.execCommand('copy');
                        if (successful) {
                            triggerToast(message);
                        } else {
                            triggerToast('複製失敗，請手動複製！');
                        }
                    } catch (err) {
                        triggerToast('瀏覽器不支援複製，請手動選取！');
                    } finally {
                        document.body.removeChild(textarea);
                    }
                };

                // 還原初始狀態
                const resetToDefault = () => {
                    if (confirm("確定要將所有數據還原為試算表原始狀態嗎？您手動新增與修改的紀錄將會被清除。")) {
                        workItems.value = JSON.parse(JSON.stringify(DEFAULT_WORK_ITEMS));
                        records.value = JSON.parse(JSON.stringify(DEFAULT_RECORDS));
                        saveToLocal();
                        if (workItems.value.length > 0) {
                            selectWorkItem(workItems.value[5]);
                        }
                        triggerToast("已還原為【CDC自檢次數統計表】之原始預設數據。");
                    }
                };

                // 解析並匯入 CSV 格式的工項資料
                const importCSV = () => {
                    const text = csvText.value.trim();
                    if (!text) {
                        triggerToast("請先輸入 CSV 或 Excel 複製而來的表格資料！");
                        return;
                    }

                    try {
                        // 支持逗號 (CSV) 或 Tab 鍵分隔的分行解析
                        const lines = text.split('\n');
                        const newWorkItems = [];
                        let parsedCount = 0;

                        lines.forEach((line, index) => {
                            // 過濾掉表頭
                            if (index === 0 && (line.includes("工項") || line.includes("LAST") || line.includes("編號"))) {
                                return;
                            }
                            
                            // 解析分隔符
                            let parts = [];
                            if (line.includes('\t')) {
                                parts = line.split('\t');
                            } else {
                                parts = line.split(',');
                            }

                            if (parts.length >= 7) {
                                const name = parts[0].trim();
                                const total = parseInt(parts[1].trim(), 10) || 0;
                                const passed = parseInt(parts[2].trim(), 10) || 0;
                                const failed = parseInt(parts[3].trim(), 10) || 0;
                                const rate = parts[4].trim();
                                const code = parts[5].trim();
                                const lastNo = parts[6].trim();

                                if (name && code && lastNo) {
                                    newWorkItems.push({
                                        name, total, passed, failed, rate, code, lastNo
                                    });
                                    parsedCount++;
                                }
                            }
                        });

                        if (newWorkItems.length > 0) {
                            workItems.value = newWorkItems;
                            saveToLocal();
                            // 預設重新選中第一個解析成功的工項
                            selectWorkItem(workItems.value[0]);
                            triggerToast(`成功解析並匯入 ${parsedCount} 項工項數據！資料庫已同步更新。`);
                            csvText.value = '';
                        } else {
                            triggerToast("無法解析任何有效行，請檢查欄位順序是否符合：[工項,總次數,合格,不合格,合格率,編號,LAST]");
                        }
                    } catch (error) {
                        console.error(error);
                        triggerToast("解析失敗，請確認資料結構無誤。");
                    }
                };

                return {
                    workItems,
                    records,
                    workQuery,
                    selectedItem,
                    editLastNo,
                    filterWorkItem,
                    filterSupervised,
                    showAddRecordModal,
                    toastMessage,
                    newRecord,
                    csvText,
                    
                    nextSerialNo,
                    autoTimestamp,
                    filteredWorkItems,
                    filteredRecords,
                    totalCheckCount,
                    totalPassCount,
                    totalFailCount,
                    overallPassRate,
                    
                    selectWorkItem,
                    updateLastNo,
                    submitRecord,
                    deleteRecord,
                    quickCopy,
                    resetToDefault,
                    importCSV
                };
            }
        }).mount('#app');
    </script>
</body>
</html>
